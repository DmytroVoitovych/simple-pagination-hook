{
  "name": "simple-pagination-hook",
  "version": "1.0.2",
  "description": "Lightweight pagination utility with math-based approach. 22x faster than alternatives.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --minify --clean",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "pagination",
    "paginator",
    "paging",
    "hook",
    "typescript",
    "react",
    "vue",
    "svelte",
    "framework-agnostic",
    "framework agnostic",
    "no dependencies",
    "tiny",
    "lightweight",
    "fast",
    "performance",
    "utility",
    "math based",
    "pure function"
  ],
  "author": {
    "name": "Dmytro Voitovych",
    "url": "https://www.linkedin.com/in/dmytro-voitovych/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DmytroVoitovych/simple-pagination-hook.git"
  },
  "bugs": {
    "url": "https://github.com/DmytroVoitovych/simple-pagination-hook/issues"
  },
  "homepage": "https://github.com/DmytroVoitovych/simple-pagination-hook#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
